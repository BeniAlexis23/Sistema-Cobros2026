PORT=4000
NODE_ENV=development
DB_AUTO_SETUP=true

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sistema_cobros

JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=8h

FRONTEND_URL=http://localhost:5173
UPLOADS_DIR=src/uploads
STORAGE_DRIVER=local

# Optional when STORAGE_DRIVER=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=TU_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=TU_SECRET_KEY
AWS_S3_BUCKET=sistema-cobros-prod-files
AWS_S3_BASE_URL=https://sistema-cobros-prod-files.s3.us-east-1.amazonaws.com
AWS_SIGNED_URL_EXPIRES_IN=300
